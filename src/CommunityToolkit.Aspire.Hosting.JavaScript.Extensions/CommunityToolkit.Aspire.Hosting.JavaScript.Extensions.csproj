<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AdditionalPackageTags>hosting nodejs vite yarn pnpm npm sveltekit typescript</AdditionalPackageTags>
    <Description>An Aspire integration for hosting NodeJS apps using Vite, Yarn, PNPM, or NPM. Includes TypeScript environment type generation for SvelteKit, Vite, and Node.js applications.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Hosting" />
    <PackageReference Include="Aspire.Hosting.JavaScript" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(SharedDir)\PathNormalizer.cs" Link="Utils\PathNormalizer.cs" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="api/" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="CommunityToolkit.Aspire.Hosting.JavaScript.Extensions.Tests" />
  </ItemGroup>

</Project>
